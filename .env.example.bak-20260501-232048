# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=bigdata

# Outbound Webhook URLs (Server -> n8n)
# Diisi agar server otomatis mem-forward event ke n8n.
# Kalau dibiarkan kosong / di-comment, fitur outbound webhook untuk channel itu di-skip.

# Trigger: BMKG poller mendeteksi gempa baru (quake_id berbeda dari fetch sebelumnya).
# Tanpa env ini, poller masih jalan & tetap simpan ke DB, tapi tidak forward ke n8n.
N8N_GEMPA_WEBHOOK_URL=https://demo-n8n.isslab.web.id/webhook-test/gempa-baru

# Trigger: setiap kali POST /api/sensor/ingest sukses tersimpan ke DB.
# Tanpa env ini, sensor data tetap masuk DB tapi tidak forward ke n8n.
N8N_THERMAL_WEBHOOK_URL=https://demo-n8n.isslab.web.id/webhook-test/sk

# Koordinat Data Center (untuk kalkulasi jarak Haversine ke epicenter gempa)
DATACENTER_LAT=-6.2088
DATACENTER_LNG=106.8456